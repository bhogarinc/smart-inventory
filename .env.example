# Application
APP_NAME=SmartInventory
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=smartinventory
DATABASE_USER=smartinv_user
DATABASE_PASSWORD=smartinv_password_change_me
DATABASE_URL=postgresql+asyncpg://smartinv_user:smartinv_password_change_me@postgres:5432/smartinventory
DATABASE_URL_SYNC=postgresql://smartinv_user:smartinv_password_change_me@postgres:5432/smartinventory

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@smartinventory.com
PGADMIN_DEFAULT_PASSWORD=admin

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@smartinventory.com

# Logging
LOG_LEVEL=INFO
